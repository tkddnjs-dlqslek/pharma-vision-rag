# ─── Anthropic (Claude Sonnet 4.7 Vision + Haiku judge) ───
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# ─── HuggingFace (Nemotron ColEmbed V2, BGE-M3, ZeRank2 downloads) ───
HF_TOKEN=hf_xxxxxxxxxxxx

# ─── Qdrant (local docker-compose default; leave URL as-is) ───
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Langfuse (cloud by default — create project at https://cloud.langfuse.com) ───
# Note: LANGFUSE_HOST was renamed to LANGFUSE_BASE_URL in recent SDK versions.
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxx
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com    # US region; use https://cloud.langfuse.com for EU

# ─── Colab Nemotron tunnel (set when running notebook with ngrok/cloudflared) ───
# Filled in at query time; leave blank until notebook prints a URL.
COLAB_EMBEDDING_URL=

# ─── Optional: Qwen3-VL (open VLM comparator via HF inference or local) ───
# QWEN_VL_ENDPOINT=https://api-inference.huggingface.co/models/Qwen/Qwen3-VL-8B

# ─── Self-hosted Langfuse (only if uncommenting docker-compose block) ───
# LANGFUSE_DB_PASSWORD=change-me
# LANGFUSE_NEXTAUTH_SECRET=run `openssl rand -hex 32`
# LANGFUSE_SALT=run `openssl rand -hex 32`
